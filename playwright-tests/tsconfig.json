{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "types": ["node"],
        "baseUrl": ".",
        "paths": {
            "@fixtures/*": ["./fixtures/*"]
        }
    },
    "include": ["**/*.ts"],
    "exclude": ["node_modules"]
}
