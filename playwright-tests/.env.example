# Copy to .env and fill in. Never commit the real .env file.

# Base URLs for the environments under test
APP_BASE_URL=
CMS_BASE_URL=

# Visible label of the auth provider button on the CMS sign-in screen.
# Use a dedicated provider for E2E so its label is stable across UI copy
# changes (e.g. "BCC Africa Guest", "E2E Test Provider").
E2E_AUTH_PROVIDER_LABEL=

# Dedicated test user credentials on the auth provider backing the deployments
E2E_USER_EMAIL=
E2E_USER_PASSWORD=

# Optional second test user, used by group-based authorization specs.
# Provision a user with a different group membership than user 1, then fill
# these in. Specs that need user 2 will skip when these are unset.
E2E_USER_2_EMAIL=
E2E_USER_2_PASSWORD=
