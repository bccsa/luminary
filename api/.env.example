PORT=3000
# 4174 = app, 4175 = CMS, 5173 = End to End tests
CORS_ORIGIN=["http://localhost:4174","http://localhost:4175","https://examplewebsite.com","http://localhost:5173"]

JWT_SECRET=""

# encryption key for encrypting and decrypting sensitive data in the database
ENCRYPTION_KEY="your-32-byte-encryption-key-here"

DB_CONNECTION_STRING="http://admin:password@127.0.0.1:5984"
DB_DATABASE="luminary-local"
DB_MAX_SOCKETS=512

# Sync tolerance in milliseconds
SYNC_TOLERANCE=1000

# Maximum `limit` accepted on a POST /query request (enforced for all query identifiers).
# Requests above this are rejected with 400. Guards against huge result-set requests.
QUERY_MAX_LIMIT=500

# Expensive-query detection (logging). A completed query examining more than
# QUERY_EXPENSIVE_DOCS_EXAMINED docs, or with an examined/returned ratio above
# QUERY_EXPENSIVE_EXAMINED_RATIO (over an internal floor), is logged as a likely scan.
QUERY_EXPENSIVE_DOCS_EXAMINED=1000
QUERY_EXPENSIVE_EXAMINED_RATIO=10

# Per-identity expensive-query rate limiter. Default OFF — enable per environment only
# after the expensive-query logs show sane thresholds. When enabled, an identity
# (userId, or anon:<ip>) that triggers repeated expensive queries past
# QUERY_RATE_LIMIT_FREE_STRIKES is blocked with HTTP 429 + Retry-After, doubling the
# backoff each strike (from BASE up to MAX); one strike is forgiven per DECAY interval.
QUERY_RATE_LIMIT_ENABLED=false
QUERY_RATE_LIMIT_FREE_STRIKES=3
QUERY_RATE_LIMIT_BASE_BACKOFF_MS=5000
QUERY_RATE_LIMIT_MAX_BACKOFF_MS=300000
QUERY_RATE_LIMIT_STRIKE_DECAY_MS=600000

# Trust the X-Forwarded-For header from a reverse proxy when deriving the client IP
# (used to key the anonymous rate-limit bucket). Enable ONLY behind a trusted proxy —
# otherwise clients can spoof X-Forwarded-For. When false, all proxied anonymous
# traffic shares one bucket (the proxy's IP).
TRUST_PROXY=false

# In-memory per-token auth identity cache. Default OFF — enable per environment to skip
# the full identity resolve (JWT verify + user lookups + lastLogin write) on repeat
# requests with the same token. The effective TTL is min(IDENTITY_CACHE_TTL_MS, the
# token's own exp), so a cached identity is never served past expiry. MAX_ENTRIES is an
# OOM guardrail (size to peak concurrent active tokens per API instance).
IDENTITY_CACHE_ENABLED=false
IDENTITY_CACHE_TTL_MS=300000
IDENTITY_CACHE_MAX_ENTRIES=50000

# Mapping between Auth0 Javascript Web Token data and group and user assignments. All mappings are optional.
JWT_MAPPINGS='{
    "groups": {
        "group-private-users": "(jwt) => jwt && jwt[\"https://your.app/metadata\"].hasMembership === true",
        "group-public-users": "(jwt) => !jwt"
    },
    "userId": "(jwt) => jwt && jwt[\"https://your.app/metadata\"].userId",
    "email": "(jwt) => jwt && jwt[\"https://your.app/metadata\"].email",
    "name": "(jwt) => jwt && jwt[\"https://your.app/metadata\"].username"
}'

# Image Processing Configuration
# Image quality for processed uploads (0-100, default: 80)
S3_IMG_QUALITY=80

#Temporary solution for upgrade script
S3_PUBLIC_ACCESS_URL="https://publicaccessurl.com"

#s3 storage audio bucket
S3_AUDIO_BUCKET="audios"

# Socket.io settings
# Optional maximum upload file size in bytes (default 10MB)
MAX_HTTP_BUFFER_SIZE=10000000

# Optional: Set to true to bypass template validation fo`r all queries (default false). This is useful for development and testing purposes.
BYPASS_TEMPLATE_VALIDATION=false

# Maximum file size for media uploads in bytes
MAX_MEDIA_UPLOAD_FILE_SIZE=15000000 # 15MB
