VITE_APP_NAME="Luminary App"

# Normal logo (Retrieved from relative path or https link)
VITE_LOGO="../src/assets/logo.svg"
VITE_LOGO_DARK="../src/assets/logo-dark.svg"
# Logo for smaller screens (Retrieved from relative path or https link)
VITE_LOGO_SMALL="../src/assets/logo-small.svg"
VITE_LOGO_SMALL_DARK="../src/assets/logo-small.svg"
VITE_LOGO_FAVICON="src/assets/favicon.png"

# ID of privacy policy page
VITE_PRIVACY_POLICY_ID="page-privacy-policy"

# Allowed Matomo servers (JSON array). Using quotes avoids parsing surprises across shells/tools.
VITE_ALLOWED_MATOMO_SERVERS='["https://localhost:8081"]'
VITE_MATOMO_SERVER=http://localhost:8080
VITE_ANALYTICS_HOST="http://localhost:8080"
VITE_ANALYTICS_SITEID="1"


# ID of copyright page
VITE_COPYRIGHT_ID="page-copyright"

VITE_API_URL="http://localhost:3000"

# Public WEB origin used by SSG for absolute canonical, Open Graph, hreflang,
# and JSON-LD URLs. Set this to the deployed public origin per environment.
VITE_WEB_ORIGIN="https://app.example.com"

# Public organization identity used in article and WebSite JSON-LD. The logo
# path is resolved against VITE_WEB_ORIGIN and must be publicly accessible.
VITE_PUBLIC_ORGANIZATION_NAME="Luminary"
VITE_PUBLIC_LOGO_PATH="/logo.svg"

VITE_SENTRY_DSN=


VITE_BYPASS_MINIFY=false
